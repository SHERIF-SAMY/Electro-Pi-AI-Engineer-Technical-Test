# LiveKit Server
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# Groq (REQUIRED — LLM is always real)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Real STT/TTS keys (leave blank to use mocks)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Mock flags (default: True)
USE_MOCK_STT=True
USE_MOCK_TTS=True

# Logging
LOG_LEVEL=INFO
